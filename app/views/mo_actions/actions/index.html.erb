<h1>Mo Actions</h1>

<% if @actions_by_category.empty? %>
  <p>No actions registered. Define one in <code>app/actions</code>.</p>
<% end %>

<% @actions_by_category.each do |category, actions| %>
  <section>
    <h2><%= category.to_s.humanize %></h2>
    <ul>
      <% actions.each do |action| %>
        <li>
          <strong><%= action.display_name %></strong>
          <% if action.description %>
            <p><%= action.description %></p>
          <% end %>

          <% if action.arguments.any? %>
            <%= form_with url: run_action_path(action.key), method: :post do %>
              <% action.arguments.each do |argument| %>
                <p>
                  <%= label_tag "arguments_#{argument.name}", argument.name.to_s.humanize %>
                  <% if argument.description %>
                    <span class="argument-description"><%= argument.description %></span>
                  <% end %>
                  <% case argument.type %>
                  <% when :boolean %>
                    <%= check_box_tag "arguments[#{argument.name}]", "1", false %>
                  <% when :integer %>
                    <%= number_field_tag "arguments[#{argument.name}]" %>
                  <% else %>
                    <%= text_field_tag "arguments[#{argument.name}]" %>
                  <% end %>
                </p>
              <% end %>
              <%= submit_tag "Run" %>
            <% end %>
          <% else %>
            <%= button_to "Run", run_action_path(action.key) %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>
