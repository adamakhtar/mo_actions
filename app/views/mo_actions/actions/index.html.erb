<h1>Mo Actions</h1>

<% if @actions_by_category.empty? %>
  <p>No actions registered. Define one in <code>app/actions</code>.</p>
<% end %>

<% @actions_by_category.each do |category, actions| %>
  <section>
    <h2><%= category.to_s.humanize %></h2>
    <ul>
      <% actions.each do |action_class| %>
        <% invalid = @invalid_action if @invalid_action&.class == action_class %>
        <li>
          <strong><%= action_class.display_name %></strong>
          <% if action_class.description %>
            <p><%= action_class.description %></p>
          <% end %>

          <% if action_class.arguments.any? %>
            <%= form_with url: run_action_path(action_class.key), method: :post do %>
              <% action_class.arguments.each do |argument| %>
                <% field_id = "arguments_#{argument.name}" %>
                <% submitted = invalid&.public_send(argument.name) %>
                <p>
                  <%= label_tag field_id, argument.name.to_s.humanize %>
                  <% if argument.required? %>
                    <span class="required">*</span>
                  <% end %>
                  <% if argument.description %>
                    <span class="argument-description"><%= argument.description %></span>
                  <% end %>
                  <% case argument.type %>
                  <% when :boolean %>
                    <%= check_box_tag "arguments[#{argument.name}]", "1", submitted == true || submitted == "1" %>
                  <% when :integer %>
                    <%= number_field_tag "arguments[#{argument.name}]", submitted, id: field_id %>
                  <% else %>
                    <%= text_field_tag "arguments[#{argument.name}]", submitted, id: field_id %>
                  <% end %>
                  <% if invalid&.errors&.include?(argument.name) %>
                    <span class="error"><%= invalid.errors.full_messages_for(argument.name).to_sentence %></span>
                  <% end %>
                </p>
              <% end %>
              <%= submit_tag "Run" %>
            <% end %>
          <% else %>
            <%= button_to "Run", run_action_path(action_class.key) %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<section class="recent-executions">
  <h2>Recent executions</h2>
  <% if @recent_executions.empty? %>
    <p>No executions yet.</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>Action</th>
          <th>Status</th>
          <th>Performer</th>
          <th>Arguments</th>
          <th>When</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_executions.each do |execution| %>
          <tr>
            <td><%= execution.action_display_name %></td>
            <td><%= execution.status %></td>
            <td><%= execution.performer&.try(:name) || execution.performer || "—" %></td>
            <td><%= execution.arguments.presence || "—" %></td>
            <td><%= execution.created_at %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
