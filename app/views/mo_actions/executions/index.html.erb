<h1>Executions</h1>

<p><%= link_to "← Actions", root_path %></p>

<%= form_with url: executions_path, method: :get do %>
  <p>
    <%= label_tag :action_key, "Action" %>
    <%= select_tag :action_key,
          options_for_select(
            [["All actions", ""]] + @filter_actions.map { |a| [a.display_name, a.key] },
            @action_key
          ) %>
    <%= submit_tag "Filter" %>
  </p>
<% end %>

<% if @action_class %>
  <p>
    <%= link_to "Run #{@action_class.display_name}", new_execution_path(action_key: @action_class.key) %>
  </p>
<% end %>

<% if @executions.empty? %>
  <p>No executions yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Action</th>
        <th>Status</th>
        <th>Progress</th>
        <th>Performer</th>
        <th>Arguments</th>
        <th>When</th>
      </tr>
    </thead>
    <tbody>
      <% @executions.each do |execution| %>
        <tr>
          <td><%= link_to execution.action_display_name, execution_path(execution) %></td>
          <td><%= execution.status %></td>
          <td>
            <% if execution.progress_total %>
              <%= execution.progress_current %> / <%= execution.progress_total %>
            <% else %>
              <%= execution.progress_current %>
            <% end %>
          </td>
          <td><%= execution.performer&.try(:name) || execution.performer || "—" %></td>
          <td><%= execution.arguments.presence || "—" %></td>
          <td><%= execution.created_at %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
