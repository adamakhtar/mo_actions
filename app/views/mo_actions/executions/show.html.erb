<h1>Execution</h1>

<p><%= link_to "← Executions", executions_path %></p>

<% if @action_class %>
  <p>
    <%= link_to "Run again",
          new_execution_path(action_key: @execution.action_key, from_execution: @execution.id) %>
  </p>
<% end %>

<% if @execution.running? %>
  <p class="running-hint"><%= link_to "Refresh", execution_path(@execution) %> to update progress.</p>
<% end %>

<dl class="execution-detail">
  <dt>Action</dt>
  <dd>
    <%= @execution.action_display_name %>
    <span class="action-key">(<%= @execution.action_key %>)</span>
  </dd>

  <dt>Status</dt>
  <dd><%= @execution.status %></dd>

  <dt>Progress</dt>
  <dd class="progress">
    <% if @execution.progress_total %>
      <%= @execution.progress_current %> / <%= @execution.progress_total %>
      <% if (percent = @execution.progress_percent) %>
        (<%= percent %>%)
      <% end %>
    <% else %>
      <%= @execution.progress_current %>
    <% end %>
  </dd>

  <dt>Performer</dt>
  <dd><%= @execution.performer&.try(:name) || @execution.performer || "—" %></dd>

  <dt>Arguments</dt>
  <dd><%= @execution.arguments.presence || "—" %></dd>

  <% if @execution.failed? && @execution.error_message.present? %>
    <dt>Error</dt>
    <dd class="error-message"><%= @execution.error_message %></dd>
  <% end %>

  <dt>Created</dt>
  <dd><%= @execution.created_at %></dd>

  <dt>Updated</dt>
  <dd><%= @execution.updated_at %></dd>
</dl>
