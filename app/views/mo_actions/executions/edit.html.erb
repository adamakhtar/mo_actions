<section class="mo-actions-draft">
  <%= link_to "Back to actions", actions_path, class: "mo-actions-back-link" %>

  <div class="mo-actions-header">
    <div>
      <p class="mo-actions-eyebrow">Draft execution</p>
      <h1><%= @action_class.name %></h1>
      <% if @action_class.description.present? %>
        <p class="mo-actions-lede"><%= @action_class.description %></p>
      <% end %>
    </div>

    <%= button_to "Abandon draft", execution_path(@execution), method: :delete, class: "mo-actions-button mo-actions-button--danger", form: { data: { turbo_confirm: "Abandon this draft?" } } %>
  </div>

  <% if notice.present? %>
    <p class="mo-actions-notice"><%= notice %></p>
  <% end %>

  <% if @preflight_results&.fetch(:errors, []).present? %>
    <section class="mo-actions-blocking-errors">
      <h2>Preflight blocked this execution</h2>
      <ul>
        <% @preflight_results.fetch(:errors).each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @arguments.errors.any? %>
    <section class="mo-actions-error-summary">
      <h2>Fix these fields before preflight</h2>
      <ul>
        <% @arguments.errors.each do |error| %>
          <li>
            <a href="#<%= argument_error_anchor(error.attribute) %>">
              <%= argument_error_label(error.attribute) %> <%= error.message %>
            </a>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <%= form_with model: @execution, url: execution_preflight_path(@execution), method: :post, class: "mo-actions-form" do |form| %>
    <% @action_class.argument_definitions.each do |definition| %>
      <%= render_argument_field(form: form, definition: definition, arguments: @arguments) %>
    <% end %>

    <div class="mo-actions-form-actions">
      <%= form.button "Save draft", name: "_method", value: "patch", formaction: execution_path(@execution), class: "mo-actions-button mo-actions-button--secondary" %>
      <%= form.submit "Run preflight", class: "mo-actions-button" %>
    </div>
  <% end %>
</section>
